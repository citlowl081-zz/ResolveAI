# ============================================================
# ResolveAI - Git Ignore
# ============================================================

# ---- Environment & Secrets ----
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials/

# ---- Python ----
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so
.Python
*.whl
.pytest_cache/
.coverage
htmlcov/
.tox/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
venv/
.venv/
**/.venv/
env/
.env-*

# ---- Node / Next.js ----
node_modules/
**/node_modules/
.next/
**/.next/
out/
*.tsbuildinfo

# ---- Local AI tooling ----
.agents/
.codex/
.claude/*.ipynb

# ---- Browser test artifacts ----
**/test-results/
**/playwright-report/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*

# ---- Docker ----
docker-compose.override.yml
.docker/

# ---- Database ----
*.db
*.sqlite
pgdata/

# ---- Logs ----
logs/
*.log

# ---- Temp ----
tmp/
temp/
*.tmp

# ---- Reports (generated) ----
reports/progress/*.html
reports/progress/*.pdf

# ---- WeChat Mini Program ----
miniprogram/project.config.json
miniprogram/project.private.config.json
# WeChat DevTools local cache & temp files
miniprogram/.idea/
miniprogram/miniprogram/.tea/
miniprogram/node_modules/

