# ResolveAI — Environment Variables
# Copy to .env and adjust. Defaults work for docker compose dev/demo.
# NEVER commit .env or .env.local to version control.

# ── Database ──
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=resolveai
POSTGRES_USER=resolveai
POSTGRES_PASSWORD=resolveai-dev

# ── Backend ──
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
JWT_SECRET_KEY=dev-secret-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── LLM Provider (mock | openai_compatible | anthropic) ──
# "mock" = deterministic mock, no API key needed (default for demo)
# Local Qwen demo: run `bash scripts/configure-qwen.sh`; never commit real values.
# Qwen placeholder: https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# Optional Anthropic: LLM_PROVIDER=anthropic  LLM_BASE_URL=https://api.anthropic.com
LLM_PROVIDER=mock
LLM_MODEL=qwen3.7-plus
LLM_API_KEY=
LLM_BASE_URL=

# ── Embedding Provider (mock | openai) ──
# "mock" = deterministic mock, no API key needed (default for demo)
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# ── Frontend URLs ──
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ── Demo Accounts (seed script only, local demo use) ──
DEMO_CUSTOMER_EMAIL=demo@example.com
DEMO_CUSTOMER_PASSWORD=demo123456
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=admin123456
