# ============================================================
# ResolveAI - Environment Variables (Example)
# ============================================================
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env or secrets to version control.

# ---- Database ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resolveai
POSTGRES_USER=resolveai
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- LLM / Model ----
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-5-20251001
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.anthropic.com
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# ---- Embedding Model (for RAG) ----
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_DIMENSION=1536

# ---- JWT / Auth ----
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- App ----
APP_NAME=ResolveAI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Agent ----
AGENT_MAX_RETRIES=2
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_SESSION_TTL_MINUTES=60
AGENT_HIGH_RISK_AMOUNT_THRESHOLD=1000.00
AGENT_MAX_CONCURRENT_SESSIONS=10

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8000/api/v1/agent/ws
