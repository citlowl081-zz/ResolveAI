page { background: #f9fafb; font-size: 28rpx; color: #1f2937; }
.container { padding: 24rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.btn { display: block; width: 100%; padding: 20rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; }
.btn-primary { background: #2563eb; color: #fff; }
.btn-danger { background: #ef4444; color: #fff; }
.btn-success { background: #16a34a; color: #fff; }
.btn-outline { background: #fff; color: #2563eb; border: 2rpx solid #2563eb; }
.input { width: 100%; padding: 20rpx; border: 2rpx solid #e5e7eb; border-radius: 12rpx; font-size: 28rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.badge { display: inline-block; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.badge-blue { background: #dbeafe; color: #1d4ed8; }
.badge-green { background: #dcfce7; color: #16a34a; }
.badge-yellow { background: #fef9c3; color: #a16207; }
.badge-red { background: #fee2e2; color: #dc2626; }
.badge-gray { background: #f3f4f6; color: #6b7280; }
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.text-sm { font-size: 24rpx; }
.text-gray { color: #6b7280; }
.text-red { color: #dc2626; }
.text-green { color: #16a34a; }
.text-blue { color: #2563eb; }
.mt-2 { margin-top: 16rpx; }
.mb-2 { margin-bottom: 16rpx; }
.loading-text { text-align: center; padding: 80rpx 0; color: #9ca3af; }
.empty-text { text-align: center; padding: 100rpx 0; color: #9ca3af; font-size: 28rpx; }
.error-text { text-align: center; padding: 40rpx; color: #dc2626; }
