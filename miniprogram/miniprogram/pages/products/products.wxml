<view class="container">
  <view style="font-size:36rpx;font-weight:bold;margin-bottom:24rpx">商品列表</view>
  <block wx:if="{{loading}}"><view class="loading-text">加载中...</view></block>
  <block wx:elif="{{items.length===0}}"><view class="empty-text">暂无商品</view></block>
  <navigator wx:for="{{items}}" wx:key="id" url="/pages/product-detail/product-detail?id={{item.id}}" class="card">
    <view class="flex-between">
      <view>
        <view style="font-weight:600">{{item.name}}</view>
        <view class="text-sm text-gray">{{item.category}}</view>
      </view>
      <view style="font-size:32rpx;font-weight:bold;color:#2563eb">¥{{item.price}}</view>
    </view>
    <view class="text-sm text-gray mt-2">库存: {{item.stock}}</view>
  </navigator>
</view>
