<view class="container">
  <view style="font-size:36rpx;font-weight:bold;margin-bottom:24rpx">售后工单</view>
  <block wx:if="{{loading}}"><view class="loading-text">加载中...</view></block>
  <block wx:elif="{{items.length===0}}"><view class="empty-text">暂无工单</view></block>
  <view wx:for="{{items}}" wx:key="id" class="card">
    <view class="flex-between">
      <text style="font-family:monospace;font-size:24rpx;color:#6b7280">{{item.ticket_number}}</text>
      <text class="badge {{item.status==='APPROVED'?'badge-green':item.status==='REJECTED'?'badge-red':item.status==='CANCELLED'?'badge-gray':'badge-yellow'}}">{{statusText[item.status]||item.status}}</text>
    </view>
    <view class="text-sm mt-2">类型: {{item.intent}}</view>
    <view wx:if="{{item.reject_reason}}" class="text-sm text-red mt-2">拒绝原因: {{item.reject_reason}}</view>
    <button wx:if="{{item.status==='APPROVED'}}" bindtap="cancel" data-id="{{item.id}}" data-ver="{{item.version}}" class="btn btn-outline" style="margin-top:16rpx;font-size:24rpx;padding:12rpx">取消工单</button>
  </view>
</view>
