<view class="container" style="padding-top:80rpx">
  <view style="text-align:center;margin-bottom:50rpx"><text style="font-size:40rpx;font-weight:bold">注册</text></view>
  <input class="input" placeholder="姓名" bindinput="onName" value="{{name}}" />
  <input class="input" placeholder="邮箱" bindinput="onEmail" value="{{email}}" />
  <input class="input" placeholder="密码(至少6位)" bindinput="onPwd" value="{{password}}" type="password" />
  <view wx:if="{{error}}" class="error-text">{{error}}</view>
  <button class="btn btn-primary" bindtap="register" loading="{{loading}}">注册</button>
  <view style="text-align:center;margin-top:30rpx">
    <navigator url="/pages/login/login" style="color:#2563eb">已有账号？立即登录</navigator>
  </view>
</view>
