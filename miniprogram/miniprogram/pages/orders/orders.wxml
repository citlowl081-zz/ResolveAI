<view class="container">
  <view style="font-size:36rpx;font-weight:bold;margin-bottom:24rpx">我的订单</view>
  <block wx:if="{{loading}}"><view class="loading-text">加载中...</view></block>
  <block wx:elif="{{items.length===0}}"><view class="empty-text">暂无订单</view></block>
  <navigator wx:for="{{items}}" wx:key="id" url="/pages/order-detail/order-detail?id={{item.id}}" class="card">
    <view class="flex-between">
      <text style="font-family:monospace;font-size:24rpx;color:#6b7280">{{item.order_number}}</text>
      <text class="badge badge-blue">{{statusText[item.status] || item.status}}</text>
    </view>
    <view style="font-size:32rpx;font-weight:bold;margin-top:12rpx">¥{{item.total_amount}}</view>
    <view class="text-sm text-gray mt-2">{{item.items.length}}件商品</view>
  </navigator>
</view>
